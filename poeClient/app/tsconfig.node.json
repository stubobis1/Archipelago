{
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "poe-version.json"],
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "out",
    "types": ["node"],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    }
  }
}
