{
  "name": "poe-archipelago-client",
  "version": "0.1.0",
  "description": "Path of Exile Archipelago Client",
  "main": "out/main/index.js",
  "author": "StuBob",
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "electron-rebuild -f -w uiohook-napi || true"
  },
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "archipelago.js": "^2.1.0",
    "archiver": "^7.0.1",
    "chokidar": "^3.6.0",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.17.1",
    "zustand": "^4.5.2"
  },
  "optionalDependencies": {
    "active-win": "^8.1.1",
    "say": "^0.16.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.11",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^4.1.5"
  }
}
